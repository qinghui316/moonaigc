generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String?  @unique
  password  String?
  name      String?
  createdAt DateTime @default(now())

  settings     UserSettings?
  projects     Project[]
  history      HistoryRecord[]
  materialSets MaterialSet[]
  gridResults  GridResult[]
}

model UserSettings {
  id     Int    @id @default(autoincrement())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Active platform settings (JSON)
  textSettings   Json @default("{}")
  visionSettings Json @default("{}")

  // Per-platform dictionaries (JSON)
  platformKeys          Json @default("{}")
  visionPlatformKeys    Json @default("{}")
  imagePlatformKeys     Json @default("{}")
  platformModels        Json @default("{}")
  visionPlatformModels  Json @default("{}")
  imagePlatformModels   Json @default("{}")
  platformEndpoints     Json @default("{}")
  visionPlatformEndpoints Json @default("{}")
  imagePlatformEndpoints  Json @default("{}")

  // Image generation settings
  imageSettings         Json @default("{}")

  // Feature flags
  autoSafety      Boolean @default(false)
  autoSound       Boolean @default(true)
  enableWordFilter Boolean @default(true)
  autoSaveHistory Boolean @default(true)
}

model Project {
  id            String   @id
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  genre         Json     @default("[]")
  audience      String   @default("")
  tone          String   @default("")
  endingType    String   @default("")
  totalEpisodes Int      @default(0)
  worldSetting  String   @default("")
  creativePlan  String   @default("")
  characterDoc  String   @default("")
  createdAt     DateTime
  updatedAt     DateTime

  // 导入剧本相关字段
  sourceMode         String @default("ai")       // "ai" | "imported"
  adaptMode          String @default("")          // "" | "faithful" | "blockbuster"
  sourceScript       String @default("")          // 导入的完整原始文本
  episodeCountMode   String @default("manual")    // "manual" | "auto"
  importStatus       String @default("idle")      // "idle" | "splitting" | "split_done" | "plan_done" | "character_done" | "failed"
  currentStep        Int    @default(0)
  lastCompletedStep  Int    @default(0)
  importError        String @default("")

  episodes     Episode[]
  history      HistoryRecord[]
  materialSets MaterialSet[]
  mediaFiles   MediaFile[]
  gridResults  GridResult[]
}

model Episode {
  id            String   @id
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  episodeNumber Int
  title         String   @default("")
  summary       String   @default("")
  hookType      String   @default("")
  mark          String   @default("")
  script        String   @default("")
  status        String   @default("outline")
  sourceText    String   @default("")  // 该集对应的原始文本片段

  history     HistoryRecord[]
  gridResults GridResult[]
}

model HistoryRecord {
  id         Int      @id @default(autoincrement())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId  String?
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  episodeId  String?
  episode    Episode? @relation(fields: [episodeId], references: [id], onDelete: SetNull)
  createdAt  DateTime
  plot       String   @default("")
  fullPlot   String   @default("")
  director   String   @default("")
  directorId String   @default("")
  storyboard String   @default("")
  time       String   @default("")

  shots       Shot[]
  gridResults GridResult[]
}

model MaterialSet {
  id        Int     @id @default(autoincrement())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  data      Json    @default("{}")

  @@unique([userId, projectId])
}

model Shot {
  id        Int    @id @default(autoincrement())
  historyId Int
  history   HistoryRecord @relation(fields: [historyId], references: [id], onDelete: Cascade)
  sortOrder Int
  timeRange String @default("")
  shotType  String @default("")
  camera    String @default("")
  scene     String @default("")
  lighting  String @default("")
  drama     String @default("")
  prompt    String @default("")
  genParams Json?

  imageFile MediaFile? @relation("ShotImage", fields: [imageFileId], references: [id])
  imageFileId Int?
  videoFile MediaFile? @relation("ShotVideo", fields: [videoFileId], references: [id])
  videoFileId Int?
}

model MediaFile {
  id        Int      @id @default(autoincrement())
  userId    String
  refType   String
  refId     String
  filePath  String
  fileName  String
  mimeType  String
  fileSize  Int
  metadata  Json?
  createdAt DateTime @default(now())

  // 项目级归属（用于画廊按项目筛选、资产图管理）
  projectId  String?
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  episodeId  String?
  assetType  String?  // "character" | "scene" | "props" | "shot"
  assetSlot  String?  // 素材槽位标识

  shotImages       Shot[]       @relation("ShotImage")
  shotVideos       Shot[]       @relation("ShotVideo")
  gridResultImages GridResult[] @relation("GridResultImage")
}

model GridResult {
  id               Int            @id @default(autoincrement())
  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId        String?
  project          Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  episodeId        String?
  episode          Episode?       @relation(fields: [episodeId], references: [id], onDelete: SetNull)
  historyId        Int?
  history          HistoryRecord? @relation(fields: [historyId], references: [id], onDelete: SetNull)
  mediaFileId      Int?
  mediaFile        MediaFile?     @relation("GridResultImage", fields: [mediaFileId], references: [id], onDelete: SetNull)
  layout           String         @default("3x3")
  aspectRatio      String         @default("16:9")
  sourceShotRefs   Json           @default("[]")
  usedReferenceImages Json        @default("[]")
  rawModelOutput   String         @default("")
  validationPassed Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  panels GridPanel[]
}

model GridPanel {
  id              Int        @id @default(autoincrement())
  gridResultId    Int
  gridResult      GridResult @relation(fields: [gridResultId], references: [id], onDelete: Cascade)
  panelOrder      Int
  timeRange       String     @default("")
  seedancePrompt  String     @default("")
  sourceSeedancePrompts Json @default("[]")
  imagePromptText String     @default("")
  sourceShotRefs  Json       @default("[]")
  createdAt       DateTime   @default(now())

  @@unique([gridResultId, panelOrder])
}
